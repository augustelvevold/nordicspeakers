---
// TODO(content): org/contact details sourced from Sanity `siteSettings`.
import { SITE } from '../lib/site';

const year = new Date().getFullYear();
const nav = [
  { href: '/foredragsholdere/', label: 'Foredragsholdere' },
  { href: '/tema/', label: 'Tema' },
  { href: '/blogg/', label: 'Blogg' },
  { href: '/kundesuksesser/', label: 'Kundesuksesser' },
  { href: '/referanser/', label: 'Referanser' },
  { href: '/om-oss/', label: 'Om oss' },
  { href: '/faq/', label: 'FAQ' },
  { href: '/kontakt/', label: 'Kontakt' },
  { href: '/book-foredrag/', label: 'Book foredrag' },
];
---
<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <p class="site-footer__name">{SITE.name}</p>
      <address class="site-footer__contact">
        Formidler profesjonelle foredragsholdere i hele Norge.
      </address>
    </div>
    <nav class="site-footer__nav" aria-label="Bunnmeny">
      <ul>
        {nav.map((i) => (
          <li><a href={i.href}>{i.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
  <div class="container site-footer__legal">
    <p>&copy; {year} {SITE.name}</p>
  </div>
</footer>
