---
// Booking/contact form. Progressive enhancement: works as a plain POST to the
// Cloudflare Pages Function (/api/book -> 303 /takk/) with NO JavaScript; the
// small script below upgrades it to an inline async submit (CLAUDE.md allows
// the booking form as an island). See functions/api/book.ts.
import type { SpeakerCardData, TopicCardData } from '../lib/queries';

interface Props {
  speakers?: Pick<SpeakerCardData, 'name'>[];
  topics?: Pick<TopicCardData, 'title'>[];
  submitLabel?: string;
}

const { speakers = [], topics = [], submitLabel = 'Send forespørsel' } = Astro.props;
---
<form id="booking-form" class="form" method="POST" action="/api/book">
  <p id="booking-status" class="form-status" role="status" aria-live="polite"></p>

  <div class="form__row">
    <div class="field">
      <label for="bf-name">Navn <span aria-hidden="true">*</span></label>
      <input id="bf-name" name="name" type="text" required autocomplete="name" />
    </div>
    <div class="field">
      <label for="bf-company">Bedrift / organisasjon</label>
      <input id="bf-company" name="company" type="text" autocomplete="organization" />
    </div>
  </div>

  <div class="form__row">
    <div class="field">
      <label for="bf-email">E-post <span aria-hidden="true">*</span></label>
      <input id="bf-email" name="email" type="email" required autocomplete="email" />
    </div>
    <div class="field">
      <label for="bf-phone">Telefon</label>
      <input id="bf-phone" name="phone" type="tel" autocomplete="tel" />
    </div>
  </div>

  <div class="form__row">
    <div class="field">
      <label for="bf-subject">Tema eller foredragsholder</label>
      <select id="bf-subject" name="subject">
        <option value="">Velg (valgfritt)</option>
        {speakers.length > 0 && (
          <optgroup label="Foredragsholdere">
            {speakers.map((s) => (
              <option value={`Foredragsholder: ${s.name}`}>{s.name}</option>
            ))}
          </optgroup>
        )}
        {topics.length > 0 && (
          <optgroup label="Temaer">
            {topics.map((t) => (
              <option value={`Tema: ${t.title}`}>{t.title}</option>
            ))}
          </optgroup>
        )}
      </select>
    </div>
    <div class="field">
      <label for="bf-date">Ønsket dato</label>
      <input id="bf-date" name="date" type="date" />
    </div>
  </div>

  <div class="field">
    <label for="bf-message">Melding <span aria-hidden="true">*</span></label>
    <textarea id="bf-message" name="message" rows="5" required
      placeholder="Fortell kort om arrangementet: type, dato, sted, antall deltakere og hva dere ønsker."></textarea>
  </div>

  {/* Honeypot — hidden from humans; bots that fill it are dropped. */}
  <div class="hp" aria-hidden="true">
    <label for="bf-company-url">La dette feltet stå tomt</label>
    <input id="bf-company-url" name="company_url" type="text" tabindex="-1" autocomplete="off" />
  </div>

  <button type="submit" class="btn btn--primary btn--lg">{submitLabel}</button>
  <p class="form__note">Vi svarer normalt innen én arbeidsdag. Ingen forpliktelser.</p>
</form>

<script>
  const form = document.getElementById('booking-form') as HTMLFormElement | null;
  const status = document.getElementById('booking-status');
  if (form && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      if (btn) btn.disabled = true;
      status.textContent = 'Sender …';
      status.className = 'form-status';
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.ok) {
          form.reset();
          form.hidden = true;
          status.className = 'form-status form-status--ok';
          status.textContent =
            'Takk! Vi har mottatt henvendelsen og svarer normalt innen én arbeidsdag.';
        } else {
          if (btn) btn.disabled = false;
          status.className = 'form-status form-status--error';
          status.textContent =
            (Array.isArray(data.errors) && data.errors.join(' ')) ||
            'Noe gikk galt. Prøv igjen, eller send oss en e-post.';
        }
      } catch {
        if (btn) btn.disabled = false;
        status.className = 'form-status form-status--error';
        status.textContent = 'Kunne ikke sende akkurat nå. Prøv igjen senere.';
      }
    });
  }
</script>
