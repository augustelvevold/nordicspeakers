---
import BaseLayout from '../layouts/BaseLayout.astro';
import { organization, website, speakableWebPage } from '../lib/schema';

// TODO(content): replace hero copy, and add featured speakers, topics and
// trust elements once Sanity content exists (step 2+, docs/roadmap.md).
const title = 'Nordic Speakers — book profesjonelle foredragsholdere';
const description =
  'Book profesjonelle foredragsholdere til bedrifter, konferanser og organisasjoner i hele Norge — innen ledelse, salg, motivasjon og mer.';

const schema = [
  organization(),
  website(),
  speakableWebPage({ name: title, url: '/', cssSelectors: ['#intro'] }),
];
---
<BaseLayout title={title} description={description} schema={schema}>
  <section class="hero">
    <div class="container">
      <h1>Norges plattform for profesjonelle foredragsholdere</h1>
      {/* Direct-answer summary — the block Speakable points at (#intro). */}
      <p id="intro" class="lead">
        Nordic Speakers formidler profesjonelle foredragsholdere til
        bedrifter, konferanser og organisasjoner over hele Norge. Beskriv
        arrangementet, så finner vi en foredragsholder som passer.
      </p>
      <p class="hero__cta">
        <a href="/book-foredrag/" class="btn btn--primary btn--lg">Book foredrag</a>
        <a href="/kontakt/" class="btn btn--ghost btn--lg">Kontakt oss</a>
      </p>
    </div>
  </section>

  {/* TODO(content): fremhevede foredragsholdere, temaer, referanser, tillitselementer. */}
</BaseLayout>
