---
import BaseLayout from '../layouts/BaseLayout.astro';
import SpeakerCard from '../components/SpeakerCard.astro';
import TopicCard from '../components/TopicCard.astro';
import Cta from '../components/Cta.astro';
import { organization, website, speakableWebPage } from '../lib/schema';
import { getFeaturedSpeakers, getAllSpeakers, getAllTopics } from '../lib/queries';

// Featured speakers on the front page; fall back to all if none are flagged.
let speakers = await getFeaturedSpeakers();
if (speakers.length === 0) speakers = await getAllSpeakers();
const topics = await getAllTopics();

const title = 'Nordic Speakers — book profesjonelle foredragsholdere';
const description =
  'Book profesjonelle foredragsholdere til bedrifter, konferanser og organisasjoner i hele Norge — innen ledelse, salg, motivasjon og mer.';

const schema = [
  organization(),
  website(),
  speakableWebPage({ name: title, url: '/', cssSelectors: ['#intro'] }),
];
---
<BaseLayout title={title} description={description} schema={schema}>
  <section class="hero">
    <div class="container">
      <h1>Norges plattform for profesjonelle foredragsholdere</h1>
      <p id="intro" class="lead">
        Nordic Speakers formidler profesjonelle foredragsholdere til bedrifter,
        konferanser og organisasjoner over hele Norge. Beskriv arrangementet, så
        finner vi en foredragsholder som passer.
      </p>
      <p class="hero__cta">
        <a href="/book-foredrag/" class="btn btn--primary btn--lg">Book foredrag</a>
        <a href="/kontakt/" class="btn btn--ghost btn--lg">Kontakt oss</a>
      </p>
    </div>
  </section>

  {speakers.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section__head">
          <h2>Foredragsholdere</h2>
          <a class="section__link" href="/foredragsholdere/">Se alle foredragsholdere →</a>
        </div>
        <div class="grid grid--cards">
          {speakers.map((s) => <SpeakerCard speaker={s} />)}
        </div>
      </div>
    </section>
  )}

  {topics.length > 0 && (
    <section class="section section--muted">
      <div class="container">
        <div class="section__head">
          <h2>Temaer</h2>
          <a class="section__link" href="/tema/">Se alle temaer →</a>
        </div>
        <div class="grid grid--cards">
          {topics.map((t) => <TopicCard topic={t} />)}
        </div>
      </div>
    </section>
  )}

  <Cta />
</BaseLayout>
