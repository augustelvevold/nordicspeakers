---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SpeakerCard from '../../components/SpeakerCard.astro';
import Cta from '../../components/Cta.astro';
import { speakableWebPage, breadcrumbList, faqPage } from '../../lib/schema';
import { renderPortableText } from '../../lib/portableText';
import { truncate } from '../../lib/text';
import { getAllTopicsDetail, type TopicDetail } from '../../lib/queries';

export async function getStaticPaths() {
  const topics = await getAllTopicsDetail();
  return topics.map((topic) => ({ params: { slug: topic.slug }, props: { topic } }));
}

interface Props {
  topic: TopicDetail;
}
const { topic } = Astro.props;

const url = `/tema/${topic.slug}/`;
const crumbs = [
  { name: 'Hjem', url: '/' },
  { name: 'Temaer', url: '/tema/' },
  { name: topic.title, url },
];

const bodyHtml = renderPortableText(topic.body);
const hasFaq = Array.isArray(topic.faq) && topic.faq.length > 0;

const schema = [
  speakableWebPage({ name: topic.title, url, cssSelectors: ['#intro'] }),
  breadcrumbList(crumbs),
  ...(hasFaq ? [faqPage(topic.faq!)] : []),
];

const title = `${topic.title} — foredrag | Nordic Speakers`;
const description = truncate(topic.intro);
---
<BaseLayout title={title} description={description} schema={schema}>
  <article class="section">
    <div class="container">
      <Breadcrumbs crumbs={crumbs} />
      <h1>{topic.title}</h1>
      <p id="intro" class="lead">{topic.intro}</p>

      {bodyHtml && <div class="prose" set:html={bodyHtml} />}

      {topic.speakers && topic.speakers.length > 0 && (
        <section class="section-block">
          <h2>Foredragsholdere innen {topic.title.toLowerCase()}</h2>
          <div class="grid grid--cards">
            {topic.speakers.map((s) => (
              <SpeakerCard speaker={s} angle={s.topics?.find((t) => t.slug === topic.slug)?.vinkling} />
            ))}
          </div>
        </section>
      )}

      {hasFaq && (
        <section class="section-block faq">
          <h2>Ofte stilte spørsmål</h2>
          {topic.faq!.map((f) => (
            <div class="faq__item">
              <h3 class="faq__q">{f.question}</h3>
              <p class="faq__a">{f.answer}</p>
            </div>
          ))}
        </section>
      )}
    </div>
  </article>
  <Cta />
</BaseLayout>
