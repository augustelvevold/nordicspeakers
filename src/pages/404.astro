---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Siden finnes ikke (404) | Nordic Speakers';
const description = 'Vi fant ikke siden du lette etter.';
---
<BaseLayout title={title} description={description} noindex={true}>
  <section class="section">
    <div class="container narrow">
      <h1>Denne siden finnes ikke</h1>
      <p class="lead">
        Beklager — vi fant ikke siden du lette etter. Den kan være flyttet eller
        fjernet.
      </p>
      <p class="hero__cta">
        <a href="/" class="btn btn--primary btn--lg">Til forsiden</a>
        <a href="/foredragsholdere/" class="btn btn--ghost btn--lg">Se foredragsholdere</a>
      </p>
    </div>
  </section>
</BaseLayout>
