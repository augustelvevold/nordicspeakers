# Copy to .env and fill in. Consumed by the Astro site (step 3+) to query Sanity.
# PUBLIC_ vars are exposed to the built client; the Sanity projectId is not secret.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
# Pin the Sanity API version (YYYY-MM-DD) so query behavior is stable across builds.
PUBLIC_SANITY_API_VERSION=2024-01-01
